# cp .env.example .env 후 값을 채운 뒤: docker compose up -d --build

NODE_ENV=production
HOSTNAME=0.0.0.0

# 컨테이너 내부 Next.js 포트
PORT=3000
# 호스트에 바인딩할 포트 (nginx upstream: 127.0.0.1:APP_PORT)
APP_PORT=3000

# 공개 URL (https, 끝 슬래시 없음) — 빌드·런타임
NEXT_PUBLIC_APP_URL=https://your-domain.example

# 외부 PostgreSQL 전체 연결 문자열 (비밀번호 특수문자는 URL 인코딩)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# 참고용 (compose는 DATABASE_URL 만 사용)
POSTGRES_HOST=host
POSTGRES_PORT=5432
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DATABASE=dbname
