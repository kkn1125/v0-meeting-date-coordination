# docker compose / 원격 배포용 환경 변수 예시
# cp .env.example .env 후 값을 채운 뒤: docker compose up -d --build

# 공개 URL (https 포함, 끝 슬래시 없음) — 빌드·런타임 모두 사용
NEXT_PUBLIC_APP_URL=https://your-domain.example

# 앱 컨테이너가 호스트에 노출하는 포트 (nginx upstream)
APP_PORT=3000

POSTGRES_USER=meeting
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=meeting
