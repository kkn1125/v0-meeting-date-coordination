# 호스트 nginx 예시 (Docker Compose 앱은 127.0.0.1:3000 에 바인딩)
# /etc/nginx/sites-available/meeting-date → sites-enabled 심볼릭 링크 후
#   sudo nginx -t && sudo systemctl reload nginx
#
# SSL은 certbot 등으로 별도 발급: certbot --nginx -d your-domain.example

map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

upstream meeting_app {
    server 127.0.0.1:3000;
    keepalive 32;
}

server {
    listen 80;
    server_name your-domain.example;

    # certbot 사용 시 HTTP → HTTPS 리다이렉트는 certbot이 추가함
    location / {
        proxy_pass http://meeting_app;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
        proxy_read_timeout 86400;
    }
}

